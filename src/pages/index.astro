---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatPostDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const workExperience = [
  {
    company: "BairesDev",
    role: "Senior Mobile Engineer",
    period: "Mar 2025 – Present",
    duration: "1 year 4 months",
    location: "Remote",
    type: "Full-time",
    highlights: [
      "Developing high-quality mobile applications for enterprise clients.",
      "Working in cross-functional teams using Agile methodologies.",
    ],
    tags: ["Kotlin", "Android", "Jetpack Compose"],
    logo: "🟠",
  },
  {
    company: "FullStack Labs",
    role: "Senior Software Engineer",
    period: "Jan 2023 – Jun 2025",
    duration: "2 years 6 months",
    location: "Santa Cruz, Bolivia · Remote",
    type: "Full-time",
    highlights: [
      "Implemented CI/CD pipelines using Fastlane for automated build and deployment.",
      "Integrated WebSocket connections for real-time features in mobile apps.",
      "Collaborated with international teams across multiple time zones.",
    ],
    tags: ["Kotlin", "Fastlane", "CI/CD", "WebSockets"],
    logo: "🔷",
  },
  {
    company: "Mojix",
    role: "Professional Service Engineer",
    period: "Jul 2022 – May 2023",
    duration: "11 months",
    location: "Bolivia",
    type: "Full-time",
    highlights: [
      "Provided professional services and technical support for mobile solutions.",
      "Implemented custom features for enterprise clients in the retail and supply chain sectors.",
    ],
    tags: ["Android", "Kotlin", "IoT"],
    logo: "🟥",
  },
  {
    company: "Jalasoft",
    role: "React Native Developer",
    period: "Jul 2022 – Feb 2023",
    duration: "8 months",
    location: "Santa Cruz, Bolivia · Remote",
    type: "Full-time",
    highlights: [
      "Developed an app to track work time from Jalasoft's employees.",
      "Implemented map-based location features using Open Street Map.",
      "Built cross-platform UI components compatible with iOS and Android.",
    ],
    tags: ["React Native", "TypeScript", "OpenStreetMap"],
    logo: "🟢",
  },
  {
    company: "Jalasoft",
    role: "Mobile Developer",
    period: "Mar 2021 – Jan 2023",
    duration: "1 year 11 months",
    location: "Bolivia",
    type: "Full-time",
    highlights: [
      "Developed iOS and Android native applications.",
      "Worked with Swift for iOS and Kotlin for Android.",
    ],
    tags: ["Android", "iOS", "Kotlin", "Swift"],
    logo: "🟢",
  },
  {
    company: "Jalasoft",
    role: "Android Developer",
    period: "Sept 2020 – Apr 2021",
    duration: "8 months",
    location: "Santa Cruz, Bolivia · Remote",
    type: "Full-time",
    highlights: [
      "Built an app for technicians to keep track of their work orders.",
      "Integrated Firebase services including Crashlytics and event logging.",
      "Implemented local database persistence using SQL.",
    ],
    tags: ["Kotlin", "Firebase", "SQL", "Android"],
    logo: "🟢",
  },
  {
    company: "Fundación Jala",
    role: "iOS/Android Developer",
    period: "2020",
    duration: "",
    location: "Bolivia",
    type: "Full-time",
    highlights: [
      "Developed mobile applications for non-profit initiatives.",
      "Gained foundational experience in both iOS and Android platforms.",
    ],
    tags: ["Android", "iOS", "Kotlin", "Swift"],
    logo: "📱",
  },
];

const skills = [
  { name: "Kotlin", color: "bg-purple-500/20 text-purple-300 border-purple-500/30" },
  { name: "Java", color: "bg-orange-500/20 text-orange-300 border-orange-500/30" },
  { name: "Android SDK", color: "bg-green-500/20 text-green-300 border-green-500/30" },
  { name: "Jetpack Compose", color: "bg-blue-500/20 text-blue-300 border-blue-500/30" },
  { name: "MVVM", color: "bg-cyan-500/20 text-cyan-300 border-cyan-500/30" },
  { name: "Clean Architecture", color: "bg-teal-500/20 text-teal-300 border-teal-500/30" },
  { name: "Coroutines", color: "bg-indigo-500/20 text-indigo-300 border-indigo-500/30" },
  { name: "Kotlin Flow", color: "bg-violet-500/20 text-violet-300 border-violet-500/30" },
  { name: "Hilt / Dagger", color: "bg-red-500/20 text-red-300 border-red-500/30" },
  { name: "Firebase", color: "bg-yellow-500/20 text-yellow-300 border-yellow-500/30" },
  { name: "Room", color: "bg-sky-500/20 text-sky-300 border-sky-500/30" },
  { name: "Retrofit", color: "bg-pink-500/20 text-pink-300 border-pink-500/30" },
  { name: "WebSockets", color: "bg-lime-500/20 text-lime-300 border-lime-500/30" },
  { name: "React Native", color: "bg-cyan-600/20 text-cyan-200 border-cyan-600/30" },
  { name: "Swift", color: "bg-orange-600/20 text-orange-200 border-orange-600/30" },
  { name: "Fastlane", color: "bg-rose-500/20 text-rose-300 border-rose-500/30" },
  { name: "CI/CD", color: "bg-emerald-500/20 text-emerald-300 border-emerald-500/30" },
  { name: "Git", color: "bg-gray-500/20 text-gray-300 border-gray-500/30" },
];

const projects = [
  {
    name: "WorkTime Tracker",
    emoji: "⏱️",
    description:
      "A cross-platform mobile app built with React Native that allows employees to clock in/out and track their work hours with real-time location verification using OpenStreetMap.",
    tags: [
      { name: "React Native", color: "bg-cyan-500/20 text-cyan-300" },
      { name: "TypeScript", color: "bg-blue-500/20 text-blue-300" },
      { name: "OpenStreetMap", color: "bg-green-500/20 text-green-300" },
    ],
  },
  {
    name: "TechOps Field App",
    emoji: "🔧",
    description:
      "An Android application designed for field technicians to manage and track work orders on the go. Features include Firebase-powered crash reporting, event tracking, and offline-first data sync.",
    tags: [
      { name: "Kotlin", color: "bg-purple-500/20 text-purple-300" },
      { name: "Firebase", color: "bg-yellow-500/20 text-yellow-300" },
      { name: "Room DB", color: "bg-sky-500/20 text-sky-300" },
    ],
  },
  {
    name: "Personal Portfolio",
    emoji: "🚀",
    description:
      "This very website! A developer portfolio built with Astro and Tailwind CSS to showcase my work experience, skills, and projects.",
    tags: [
      { name: "Astro", color: "bg-orange-500/20 text-orange-300" },
      { name: "Tailwind CSS", color: "bg-teal-500/20 text-teal-300" },
      { name: "TypeScript", color: "bg-blue-500/20 text-blue-300" },
    ],
  },
];
---

<Layout>
  <!-- Navbar -->
  <nav class="sticky top-0 z-50 border-b border-[#21262d]" style="background-color: rgba(13,17,23,0.85); backdrop-filter: blur(12px);">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 font-bold text-lg group">
        <span class="text-2xl">📱</span>
        <span class="text-white group-hover:text-cyan-400 transition-colors">Christian's Blog</span>
      </a>

      <!-- Nav Links -->
      <div class="flex items-center gap-6">
        <a
          href="/blog"
          class="text-[#8b949e] hover:text-white transition-colors text-sm font-medium"
        >
          Blog
        </a>
        <a
          href="https://github.com/electricpairs01"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[#8b949e] hover:text-white transition-colors text-sm font-medium"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/christian-torrico/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[#8b949e] hover:text-white transition-colors text-sm font-medium"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="max-w-5xl mx-auto px-6">

    <!-- Hero Section -->
    <section class="py-16 flex flex-col md:flex-row items-center gap-12 md:gap-6">
      <!-- Text Side -->
      <div class="flex-1">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
          Hi there, I'm <span class="text-cyan-400">Christian</span> 👋
        </h1>
        <p class="text-[#8b949e] text-lg leading-relaxed mb-2">
          <span class="text-cyan-400 font-medium">Senior Mobile Engineer</span> with 5+ years of experience crafting
          high-quality native and cross-platform mobile applications.
        </p>
        <p class="text-[#8b949e] text-lg leading-relaxed mb-6">
          Based in <span class="text-white font-medium">Santa Cruz, Bolivia</span>. Specialized in
          <span class="text-white font-medium">Kotlin</span>,
          <span class="text-white font-medium">Jetpack Compose</span>, and modern Android architecture patterns.
          Currently working remotely at <span class="text-cyan-400 font-medium">BairesDev</span>.
        </p>

        <!-- Social Icons -->
        <div class="flex items-center gap-3">
          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/in/christian-torrico/"
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 rounded-xl flex items-center justify-center bg-[#0A66C2] hover:bg-[#0856a3] transition-all hover:scale-110"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5 text-white fill-white" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>

          <!-- GitHub -->
          <a
            href="https://github.com/electricpairs01"
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 rounded-xl flex items-center justify-center bg-[#24292e] hover:bg-[#3d444d] transition-all hover:scale-110 border border-[#30363d]"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </a>

          <!-- Medium -->
          <a
            href="https://medium.com/@electricomposer"
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 rounded-xl flex items-center justify-center bg-[#242424] hover:bg-[#3a3a3a] transition-all hover:scale-110 border border-[#30363d]"
            aria-label="Medium"
          >
            <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Avatar Side -->
      <div class="flex-shrink-0 flex items-center justify-center">
                <div class="relative w-56 h-56 md:w-64 md:h-64 rounded-3xl overflow-hidden border border-[#30363d] flex items-center justify-center">
          <div class="absolute inset-0 bg-gradient-to-br from-[#1f2d3d] to-[#0d1117]"></div>
          <img
            src="/profile.jpeg"
            alt="Christian Torrico"
            class="relative w-48 h-48 md:w-56 md:h-56 rounded-full object-cover z-10"
          />
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="py-10 border-t border-[#21262d]">
      <h2 class="text-2xl font-bold text-white mb-6">
        My <span class="text-cyan-400">Skills</span>
      </h2>
      <div class="flex flex-wrap gap-2">
        {skills.map((skill) => (
          <span class={`px-3 py-1.5 rounded-full text-sm font-medium border ${skill.color} transition-transform hover:scale-105`}>
            {skill.name}
          </span>
        ))}
      </div>
    </section>

    <!-- Work Experience Section -->
    <section class="py-10 border-t border-[#21262d]">
      <h2 class="text-2xl font-bold text-white mb-8">
        Work <span class="text-cyan-400">Experience</span>
      </h2>
      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-4 top-2 bottom-2 w-0.5 bg-gradient-to-b from-cyan-500 via-[#30363d] to-transparent hidden md:block"></div>

        <div class="space-y-6">
          {workExperience.map((job, index) => (
            <div class="relative md:pl-12 group">
              <!-- Timeline dot -->
              <div class="absolute left-2 top-6 w-4 h-4 rounded-full bg-[#0d1117] border-2 border-cyan-500 hidden md:flex items-center justify-center group-hover:border-cyan-300 transition-colors">
                <div class="w-1.5 h-1.5 rounded-full bg-cyan-500 group-hover:bg-cyan-300 transition-colors"></div>
              </div>

              <div class="rounded-xl p-5 border border-[#30363d] hover:border-cyan-500/40 transition-all bg-[#161b22] hover:bg-[#1a2234]">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                  <div>
                    <h3 class="text-white font-bold text-lg">{job.role}</h3>
                    <p class="text-cyan-400 font-medium text-sm">{job.company}</p>
                  </div>
                  <div class="text-right shrink-0">
                    <p class="text-[#8b949e] text-sm">{job.period}</p>
                    {job.duration && <p class="text-[#6e7681] text-xs">{job.duration}</p>}
                    <p class="text-[#6e7681] text-xs mt-1">📍 {job.location}</p>
                  </div>
                </div>

                <ul class="space-y-1 mb-3">
                  {job.highlights.map((highlight) => (
                    <li class="text-[#8b949e] text-sm flex items-start gap-2">
                      <span class="text-cyan-500 mt-1 shrink-0">▸</span>
                      <span>{highlight}</span>
                    </li>
                  ))}
                </ul>

                <div class="flex flex-wrap gap-1.5 mt-3">
                  {job.tags.map((tag) => (
                    <span class="px-2 py-0.5 rounded-md text-xs font-medium bg-[#0d1117] text-[#8b949e] border border-[#30363d]">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Recent Projects Section -->
    <section class="py-10 border-t border-[#21262d]">
      <h2 class="text-2xl font-bold text-white mb-8">
        Recent <span class="text-cyan-400">Projects</span>
      </h2>
      <div class="space-y-4">
        {projects.map((project) => (
          <div class="flex flex-col sm:flex-row items-start gap-5 rounded-xl p-6 border border-[#30363d] hover:border-cyan-500/40 bg-[#161b22] hover:bg-[#1a2234] transition-all">
            <div class="w-16 h-16 rounded-2xl bg-[#0d1117] border border-[#30363d] flex items-center justify-center text-4xl shrink-0">
              {project.emoji}
            </div>
            <div class="flex-1">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <h3 class="text-white font-bold text-lg">{project.name}</h3>
                <div class="flex flex-wrap gap-1.5">
                  {project.tags.map((tag) => (
                    <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${tag.color}`}>
                      {tag.name}
                    </span>
                  ))}
                </div>
              </div>
              <p class="text-[#8b949e] text-sm leading-relaxed">{project.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Recent Posts Section -->
    <section class="py-10 border-t border-[#21262d]">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-white">
          Recent <span class="text-cyan-400">Posts</span>
        </h2>
        <a
          href="/blog"
          class="text-sm text-[#8b949e] hover:text-cyan-400 transition-colors font-medium flex items-center gap-1"
        >
          View all posts →
        </a>
      </div>

      <!-- Post cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
        {recentPosts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group rounded-xl overflow-hidden border border-[#30363d] bg-[#161b22] hover:border-cyan-500/40 hover:bg-[#1a2234] transition-all block"
          >
            <div class="overflow-hidden h-44">
              <img
                src={post.data.image}
                alt={post.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-5 text-center">
              <h3 class="text-white font-bold text-sm leading-snug mb-1.5 group-hover:text-cyan-400 transition-colors">
                {post.data.title}
              </h3>
              <p class="text-[#6e7681] text-xs mb-2">{formatPostDate(post.data.date)}</p>
              <p class="text-[#8b949e] text-xs leading-relaxed line-clamp-3">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Contact / Newsletter Section -->
    <section class="py-10 border-t border-[#21262d]">
      <div class="rounded-2xl p-8 bg-gradient-to-br from-[#0d2137] to-[#0d1117] border border-cyan-900/30">
        <div class="flex flex-col md:flex-row items-center gap-8">
          <div class="flex-1">
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">
              Let's <span class="text-cyan-400">Connect</span>
            </h2>
            <p class="text-[#8b949e] leading-relaxed">
              Whether you have a project in mind, want to collaborate, or just want to chat about Android development — my inbox is always open!
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 shrink-0">
            <a
              href="https://www.linkedin.com/in/christian-torrico/"
              target="_blank"
              rel="noopener noreferrer"
              class="px-6 py-3 rounded-xl bg-cyan-500 hover:bg-cyan-400 text-black font-bold transition-all hover:scale-105 text-sm text-center"
            >
              Get in Touch
            </a>
            <a
              href="/blog"
              class="px-6 py-3 rounded-xl border border-[#30363d] hover:border-cyan-500/40 text-white font-medium transition-all hover:scale-105 text-sm text-center bg-[#161b22] hover:bg-[#1a2234]"
            >
              Read my Blog
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="border-t border-[#21262d] mt-10">
    <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-[#6e7681] text-sm">
        © {new Date().getFullYear()} Christian Torrico. Built with
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-cyan-400 hover:text-cyan-300 transition-colors">Astro</a>
        &
        <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="text-cyan-400 hover:text-cyan-300 transition-colors">Tailwind CSS</a>.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://www.linkedin.com/in/christian-torrico/" target="_blank" rel="noopener noreferrer" class="text-[#6e7681] hover:text-white transition-colors text-sm">LinkedIn</a>
        <a href="https://github.com/electricpairs01" target="_blank" rel="noopener noreferrer" class="text-[#6e7681] hover:text-white transition-colors text-sm">GitHub</a>
        <a href="https://medium.com/@electricomposer" target="_blank" rel="noopener noreferrer" class="text-[#6e7681] hover:text-white transition-colors text-sm">Medium</a>
      </div>
    </div>
  </footer>
</Layout>