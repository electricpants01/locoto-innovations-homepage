---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<Layout title="Blog | Christian Torrico">

  <!-- Navbar -->
  <nav
    class="sticky top-0 z-50 border-b border-[#21262d]"
    style="background-color: rgba(13,17,23,0.90); backdrop-filter: blur(12px);"
  >
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-7 h-7 text-cyan-400">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <path d="M8 21h8M12 17v4"/>
            <path d="M7 8h2M7 12h10M15 8h2"/>
          </svg>
        </div>
        <span class="font-bold text-white text-base group-hover:text-cyan-400 transition-colors">
          Christian's Blog
        </span>
      </a>

      <!-- Nav links -->
      <div class="flex items-center gap-6">
        <a href="/blog" class="text-sm font-medium text-cyan-400">Blog</a>
        <a
          href="https://github.com/electricpairs01"
          target="_blank" rel="noopener noreferrer"
          class="text-sm font-medium text-[#8b949e] hover:text-white transition-colors"
        >GitHub</a>
        <a
          href="https://www.linkedin.com/in/christian-torrico/"
          target="_blank" rel="noopener noreferrer"
          class="text-sm font-medium text-[#8b949e] hover:text-white transition-colors"
        >LinkedIn</a>
      </div>
    </div>
  </nav>

  <!-- Page header -->
  <section class="pt-16 pb-10 text-center max-w-3xl mx-auto px-6">
    <h1 class="text-4xl font-bold text-white mb-4">Android Dev Blog</h1>
    <p class="text-[#8b949e] text-lg">
      Practical articles on Kotlin, Jetpack Compose, Clean Architecture, and modern Android engineering.
    </p>
  </section>

  <!-- Posts grid -->
  <main class="max-w-5xl mx-auto px-6 pb-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="group rounded-xl overflow-hidden border border-[#30363d] bg-[#161b22] hover:border-cyan-500/40 hover:bg-[#1a2234] transition-all block"
        >
          <!-- Cover image -->
          <div class="overflow-hidden h-48">
            <img
              src={post.data.image}
              alt={post.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>

          <!-- Card body -->
          <div class="p-5 text-center">
            <h2 class="text-white font-bold text-base leading-snug mb-2 group-hover:text-cyan-400 transition-colors">
              {post.data.title}
            </h2>
            <p class="text-[#6e7681] text-xs mb-3">{formatDate(post.data.date)}</p>
            <p class="text-[#8b949e] text-sm leading-relaxed line-clamp-3">
              {post.data.description}
            </p>
          </div>

          <!-- Tags -->
          <div class="px-5 pb-5 flex flex-wrap gap-1.5 justify-center">
            {post.data.tags.slice(0, 3).map((tag) => (
              <span class="px-2 py-0.5 rounded-md text-xs font-medium bg-[#0d1117] text-[#8b949e] border border-[#30363d]">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[#21262d]">
    <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-[#6e7681] text-sm">© 2026 Christian Torrico</p>
      <div class="flex gap-5">
        <a href="/" class="text-[#6e7681] hover:text-white transition-colors text-sm">Home</a>
        <a href="https://github.com/electricpairs01" target="_blank" rel="noopener noreferrer" class="text-[#6e7681] hover:text-white transition-colors text-sm">GitHub</a>
        <a href="https://www.linkedin.com/in/christian-torrico/" target="_blank" rel="noopener noreferrer" class="text-[#6e7681] hover:text-white transition-colors text-sm">LinkedIn</a>
      </div>
    </div>
  </footer>

</Layout>
